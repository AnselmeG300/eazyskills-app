# Frontend environment variables
# Copy this file to .env.local and fill in the values

# URL of the backend chat endpoint (AWS API Gateway or local)
BACKEND_CHAT_URL=https://your-api-id.execute-api.region.amazonaws.com/prod/chat

# API key for the backend (x-api-key header)
API_KEY=your-api-key-here

# Resend (email service) configuration
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_TO_EMAIL=contact@yourdomain.com
