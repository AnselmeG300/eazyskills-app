# Backend environment variables
# Copy this file to .env and fill in the values

# Database connection URL (PostgreSQL for production, SQLite for local dev)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# OpenAI API key
OPENAI_API_KEY=sk-...

# Backend base URL (used for internal service calls)
BACKEND_BASE_URL=http://localhost:8000

# Deployment environment: DEV | DEPLOY
ENV=DEV
